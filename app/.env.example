# Copy to .env.local for `npm run dev` / local `npm run build`.
# CI sets these from GitHub Actions secrets/vars (see .github/workflows/static.yml).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; when set, initializes App Check (reCAPTCHA v3) like the main site.
VITE_FIREBASE_APP_CHECK_SITE_KEY=
